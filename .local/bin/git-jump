#!/bin/sh

# This is taken from git-jump, however, just rewritten in a way that I would write my shell.

usage() {
	cat <<\EOF >&2
usage: git jump [--stdout] <mode> [<args>]

Jump to interesting elements in an editor.
The <mode> parameter is one of:

diff: elements are diff hunks. Arguments are given to diff.

merge: elements are merge conflicts. Arguments are given to ls-files -u.

grep: elements are grep hits. Arguments are given to git grep or, if
      configured, to the command in `jump.grepCmd`.

ws: elements are whitespace errors. Arguments are given to diff --check.

If the optional argument `--stdout` is given, print the quickfix
lines to standard output instead of feeding it to the editor.
EOF
}

__diff() {
	git diff --no-prefix --relative "$@" |
	perl -ne '
	if (m{^\+\+\+ (.*?)\t?$}) { $file = $1 eq "/dev/null" ? undef : $1; next }
	defined($file) or next;
	if (m/^@@ .*?\+(\d+)/) { $line = $1; next }
	defined($line) or next;
	if (/^ /) { $line++; next }
	if (/^[-+]\s*(.*)/) {
		print "$file:$line:1: $1\n";
		$line = undef;
	}
	'
}

__merge() {
	git ls-files -u "$@" |
	perl -pe 's/^.*?\t//' |
	sort -u |
	while IFS= read fn; do
		grep -Hn '^<<<<<<<' "$fn"
	done
}

__grep() {
	local cmd=$(git config jump.grepCmd)
	[ -n "$cmd" ] || cmd="git grep -n --column"
	$cmd "$@" |
	sed '
	s/[ \t]+/ /g;
	s/^ *//;
	'
}

__ws() {
	git diff --check "$@"
}

use_stdout=
while [ $# -gt 0 ]; do
	case "$1" in
	--stdout)
		use_stdout=t
		;;
	--*)
		usage
		exit 1
		;;
	*)
		break
		;;
	esac
	shift
done
if [ $# -lt 1 ]; then
	mode=merge
else
	mode=$1; shift
fi
type "__$mode" >/dev/null 2>&1 || { usage ; exit 1; }

if [ "$use_stdout" = "t" ]; then
	__$mode "$@"
	exit 0
fi

trap 'rm -f "$tmp"' 0 1 2 3 15
tmp=$(mktemp -t git-jump.XXXXXX) || exit 1
__$mode "$@" > $tmp
[ -s "$tmp" ] || exit 0
$(git var GIT_EDITOR) -q $tmp
